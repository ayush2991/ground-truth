FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Pre-download models at build time to avoid cold-start delays
# This is critical for fast startup on Railway
RUN python -c "from transformers import pipeline; \
    print('Downloading T5 claim extraction model...'); \
    pipeline('text2text-generation', model='Babelscape/t5-base-summarization-claim-extractor', device=-1); \
    print('Downloading DeBERTa NLI model...'); \
    pipeline('text-classification', model='MoritzLaurer/DeBERTa-v3-base-mnli-fever-anli', device=-1, top_k=None); \
    print('Models downloaded successfully')"

# Copy application code
COPY app/ app/

# Expose port
EXPOSE 8000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD python -c "import requests; requests.get('http://localhost:8000/health')"

# Run the application
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
